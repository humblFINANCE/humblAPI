# ENVIRONMENT ("development" or "production") is the variable read by
# core/config.py and core/env.py. Defaults to "development" if unset.
ENVIRONMENT=development
LOGGER_LEVEL=INFO

# OpenBB Platform API. Both dev and prod point at the same self-hosted,
# production OpenBB instance - there is no local OpenBB by default. See
# humblWORKSPACE's `pixi run dev:local-openbb` if you need to run OpenBB
# locally instead (e.g. testing an OpenBB version bump).
OPENBB_API_DEV_URL=https://data.humblfinance.io
OPENBB_API_PREFIX=/api/v1
OPENBB_API_PROD_URL=https://data.humblfinance.io

REDIS_REST_API_URL="https://<your-upstash-redis-url>"
REDIS_API_TOKEN="<your-upstash-redis-token>"
REDIS_REST_API_READ_ONLY_TOKEN="<your-upstash-redis-read-only-token>"

FLUSH_API_TOKEN="<your-flush-api-token>"
OBB_PAT=json.web.token